{
  "name": "recap-agent",
  "version": "0.1.0",
  "description": "Serverless conversational agent runtime for Sin Envolturas.",
  "private": true,
  "main": "dist/lambda/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "terminal": "tsx src/terminal/client.ts",
    "terminal:live": "tsx src/terminal/client.ts --live",
    "check": "npm run typecheck && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.913.0",
    "@aws-sdk/client-lambda": "^3.913.0",
    "@aws-sdk/client-secrets-manager": "^3.913.0",
    "@aws-sdk/lib-dynamodb": "^3.913.0",
    "@openai/agents": "^0.8.2",
    "openai": "^6.33.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.2",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20.5.0"
  }
}
