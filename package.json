{
  "name": "recap-agent",
  "version": "0.1.0",
  "description": "Serverless conversational agent runtime for Sin Envolturas.",
  "private": true,
  "main": "dist/lambda/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node scripts/build.mjs",
    "deploy": "node scripts/deploy.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "eval": "tsx src/evals/cli.ts run",
    "eval:list": "tsx src/evals/cli.ts list",
    "eval:report": "tsx src/evals/cli.ts report",
    "sync:providers": "tsx scripts/sync-provider-search.ts",
    "terminal": "bun run src/terminal/client.ts",
    "terminal:node": "tsx src/terminal/client.ts",
    "purge:terminal-plans": "node scripts/purge-terminal-plans.mjs",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.1024.0",
    "@aws-sdk/client-dynamodb": "^3.913.0",
    "@aws-sdk/client-lambda": "^3.913.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/client-secrets-manager": "^3.913.0",
    "@aws-sdk/lib-dynamodb": "^3.913.0",
    "@openai/agents": "^0.8.2",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "node-html-parser": "^7.1.0",
    "openai": "^6.33.0",
    "picocolors": "^1.1.1",
    "ulid": "^3.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.30.1",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
