AWS_PROFILE=se-dev
AWS_REGION=us-east-1
STACK_NAME=recap-agent-runtime
TERMINAL_USER_ID=51999999999
TERMINAL_CONTACT_PHONE=
TERMINAL_CHANNEL=terminal_whatsapp
CLI_TIMEOUT_MS=90000

# Optional overrides. If omitted, the CLI resolves these from CloudFormation.
# AGENT_FUNCTION_URL=https://...
# CHANNEL_API_KEY=replace_with_a_random_32_byte_or_longer_secret
# PLANS_TABLE_NAME=recap-agent-runtime-plans
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_EXTRACTOR_MODEL=gpt-5.4-nano
# OPENAI_RESPONSE_CLASSIFIER_MODEL=gpt-5.4-nano
# RESPONSE_CLASSIFIER_MODE=enforce
# OPENAI_PROMPT_CACHE_RETENTION=in-memory
# PERF_RETENTION_DAYS=30
# REPLY_PROVIDER_LIMIT=4

# Vector store IDs. Required for hybrid provider search and FAQ knowledge base.
# Get these from your OpenAI dashboard or by running `npm run sync:providers`.
# PROVIDER_VECTOR_STORE_ID=vs_...
# KB_VECTOR_STORE_ID=vs_...

# Human escalation Agent API.
# AGENT_API_BASE_URL=https://api.sinenvolturas.com/api/agent
# AGENT_API_TIMEOUT_MS=5000
# AGENT_API_MAX_RETRIES=2

# Deployment-only secret source. Do not commit your real value.
OPENAI_API_KEY=replace_me_for_deploy_only
SE_API_KEY=replace_me_for_deploy_only
CHANNEL_API_KEY=replace_me_for_deploy_only
